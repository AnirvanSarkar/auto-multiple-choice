use warnings;
use 5.012;

my $mode = lc($ARGV[0] || 'full');

if($mode eq 'full') {
    print "@/PACKAGE_V_STY/@\n";
} elsif($mode eq 'commit') {
    print "@/PACKAGE_V_VC/@\n";
} elsif($mode eq 'tag') {
    print "@/PACKAGE_V_DEB/@\n";
} elsif($mode eq 'date') {
    print "@/PACKAGE_V_ISODATE/@\n";
} else {
    die "Unknown";
}
